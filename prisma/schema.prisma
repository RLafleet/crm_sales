generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  new
  thinking
  warm
  hot
  call_later
  revisit
  not_relevant
  refused
  connected
}

enum LeadPriority {
  low
  medium
  high
}

enum WarmnessLevel {
  cold
  warm
  hot
}

enum ContactType {
  door
  call
  telegram
  whatsapp
}

enum TaskType {
  call
  revisit
  message
}

enum TaskStatus {
  open
  done
  skipped
}

model Client {
  id                          String          @id @default(cuid())
  fullName                    String
  phone                       String          @unique
  address                     String
  entrance                    String?
  floor                       String?
  apartment                   String?
  currentOperator             String?
  usesHomeInternet            Boolean         @default(false)
  usesMobile                  Boolean         @default(false)
  usesTV                      Boolean         @default(false)
  currentMonthlyPrice         Int?
  connectionType              String?
  hasSmartTV                  Boolean         @default(false)
  needsSetTopBox              Boolean         @default(false)
  householdSize               Int?
  numberPortabilityImportant  Boolean         @default(false)
  familyPlanPotential         Boolean         @default(false)
  decisionMaker               String?
  leadStatus                  LeadStatus      @default(new)
  leadPriority                LeadPriority    @default(medium)
  warmnessLevel               WarmnessLevel   @default(cold)
  preferredCallTime           String?
  nextFollowUpAt              DateTime?
  revisitNeeded               Boolean         @default(false)
  notes                       String?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  lastContactAt               DateTime?
  contacts                    ContactHistory[]
  tasks                       FollowUpTask[]
}

model ContactHistory {
  id           String       @id @default(cuid())
  client       Client       @relation(fields: [clientId], references: [id])
  clientId     String
  contactType  ContactType
  result       String?
  notes        String?
  nextActionAt DateTime?
  createdAt    DateTime     @default(now())
}

model FollowUpTask {
  id        String     @id @default(cuid())
  client    Client     @relation(fields: [clientId], references: [id])
  clientId  String
  type      TaskType
  dueAt     DateTime
  status    TaskStatus @default(open)
  notes     String?
  createdAt DateTime   @default(now())
}
